<section class="mb-5 p-6 border border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_15px_#7ec0ce,0_0_30px_#7ec0ce]">
  <h1 class="text-3xl font-bold text-[#f1f1f1] mb-3">Admin User Management</h1>
  <p class="text-[#7ec0ce]">
    Admin accounts can add new users, assign roles, and remove existing users from the
    in-memory user repository.
  </p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="grid grid-cols-1 md:grid-cols-[minmax(280px,0.9fr)_minmax(0,1.1fr)] gap-5">
  <section class="p-6 border border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_15px_#7ec0ce,0_0_30px_#7ec0ce]">
    <div class="mb-4">
      <h2 class="text-xl font-semibold mb-2 text-[#f1f1f1]">Add User</h2>
      <p class="text-[#7ec0ce]">Create a new admin, staff, or user account with a hashed password.</p>
    </div>

    <form class="grid gap-2.5" method="post" action="/admin/users">
      <label for="displayName" class="text-sm font-medium text-[#f1f1f1]">Display Name</label>
      <input
        id="displayName"
        name="displayName"
        required
        class="w-full px-3 py-2.5 border border-[#7ec0ce] rounded-xl bg-[#0d1525] text-[#f1f1f1] placeholder-[#7ec0ce]/60 focus:outline-none focus:border-[#4685FF]"
      />

      <label for="email" class="text-sm font-medium text-[#f1f1f1]">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        required
        class="w-full px-3 py-2.5 border border-[#7ec0ce] rounded-xl bg-[#0d1525] text-[#f1f1f1] placeholder-[#7ec0ce]/60 focus:outline-none focus:border-[#4685FF]"
      />

      <label for="password" class="text-sm font-medium text-[#f1f1f1]">Password</label>
      <input
        id="password"
        name="password"
        type="password"
        autocomplete="new-password"
        required
        class="w-full px-3 py-2.5 border border-[#7ec0ce] rounded-xl bg-[#0d1525] text-[#f1f1f1] placeholder-[#7ec0ce]/60 focus:outline-none focus:border-[#4685FF]"
      />

      <label for="role" class="text-sm font-medium text-[#f1f1f1]">Role</label>
      <select
        id="role"
        name="role"
        class="w-full px-3 py-2.5 border border-[#7ec0ce] rounded-xl bg-[#0d1525] text-[#f1f1f1] focus:outline-none focus:border-[#4685FF]"
      >
        <option value="user">User</option>
        <option value="staff">Staff</option>
        <option value="admin">Admin</option>
      </select>

      <button
        type="submit"
        class="mt-1 px-4 py-2.5 rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#7ec0ce] font-medium cursor-pointer hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
      >
        Add User
      </button>
    </form>
  </section>

  <section class="p-6 border border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_15px_#7ec0ce,0_0_30px_#7ec0ce]">
    <div class="mb-4">
      <h2 class="text-xl font-semibold mb-2 text-[#f1f1f1]">Existing Users</h2>
      <p class="text-[#7ec0ce]">The admin can remove any account except the currently signed-in admin.</p>
    </div>

    <ul class="list-none m-0 p-0 grid gap-3.5">
      <% users.forEach((user) => { %>
        <li class="flex items-center justify-between gap-4 p-4 border border-[#7ec0ce]/40 rounded-xl bg-[#0d1525] hover:border-[#7ec0ce] transition-colors">
          <div>
            <strong class="text-[#f1f1f1]"><%= user.displayName %></strong>
            <p class="text-sm text-[#7ec0ce] mt-0.5 mb-0"><%= user.email %></p>
            <p class="text-sm text-[#7ec0ce] mb-0">role=<%= user.role %></p>
          </div>

          <% if (session.authenticatedUser && session.authenticatedUser.userId === user.id) { %>
            <span class="inline-flex items-center justify-center min-w-[110px] px-2.5 py-1.5 rounded-full text-sm font-semibold capitalize bg-[#4685FF]/20 text-[#7ec0ce]">
              Current Admin
            </span>
          <% } else { %>
            <form method="post" action="/admin/users/<%= user.id %>/delete" class="m-0">
              <button
                type="submit"
                class="px-3.5 py-2 rounded-lg bg-[#cf4646] text-white font-medium cursor-pointer hover:bg-[#a33535] text-sm"
              >
                Remove
              </button>
            </form>
          <% } %>
        </li>
      <% }) %>
    </ul>
  </section>
</section>
