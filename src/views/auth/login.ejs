<section class="mb-5 p-6 border-2 border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
  <h1 class="text-3xl font-bold text-[#f1f1f1] mb-3">Sign In</h1>
  <p class="text">
    Log in with one of the demo accounts below to access the application.
  </p>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border-2 border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Log In</h2>
    <p class="text">
      This starter uses three in-memory demo users with hashed passwords so you
      can focus on building your project features.
    </p>
  </div>

  <form class="grid gap-2.5" method="post" action="/login">
    <label for="email" class="text-sm font-medium text-[#f1f1f1]">Email</label>
    <input
      id="email"
      name="email"
      type="email"
      autocomplete="username"
      required
      class="w-full px-3 py-2.5 border-2 border-[#7ec0ce] rounded-xl bg-[#16213e] text-[#f1f1f1] focus:outline-2 focus:outline-[#7ec0ce]/20 focus:border-[#7ec0ce]"
    />

    <label for="password" class="text-sm font-medium text-[#f1f1f1]">Password</label>
    <input
      id="password"
      name="password"
      type="password"
      autocomplete="current-password"
      required
      class="w-full px-3 py-2.5 border-2 border-[#7ec0ce] rounded-xl bg-[#16213e] text-[#f1f1f1] focus:outline-2 focus:outline-[#7ec0ce]/20 focus:border-[#7ec0ce]"
    />

    <button
      type="submit"
      class="mt-1 px-4 py-2.5 rounded-lg bg-[#df3a9e] text-[#f1f1f1] font-medium cursor-pointer hover:bg-[#d12c90]"
    >
      Log in
    </button>
  </form>

  <div class="mt-5 pt-5 border-t border-[#7ec0ce]">
    <h3 class="text-base font-semibold mb-2 text-[#f1f1f1]">Demo Users</h3>
    <ul class="list-disc pl-5 space-y-1 text-sm text-[#f1f1f1]">
      <li><code class="bg-[#214F82] px-1 rounded">admin@app.test</code> / <code class="bg-[#214F82] px-1 rounded">password123</code> / <code class="bg-[#214F82] px-1 rounded">Admin</code></li>
      <li><code class="bg-[#214F82] px-1 rounded">staff@app.test</code> / <code class="bg-[#214F82] px-1 rounded">password123</code> / <code class="bg-[#214F82] px-1 rounded">Staff</code></li>
      <li><code class="bg-[#214F82] px-1 rounded">user@app.test</code> / <code class="bg-[#214F82] px-1 rounded">password123</code> / <code class="bg-[#214F82] px-1 rounded">User</code></li>
    </ul>
  </div>
</section>