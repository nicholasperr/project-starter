<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>

<% const statusStyles = {
  draft: "border-amber-200 bg-amber-50 text-amber-800",
  published: "border-emerald-200 bg-emerald-50 text-emerald-800",
  cancelled: "border-rose-200 bg-rose-50 text-rose-800",
  past: "border-slate-200 bg-slate-100 text-slate-700"
}; %>

<section
  id="event-lifecycle-panel"
  class="space-y-4"
  x-data="{ changed: false }"
  x-init="changed = true; setTimeout(() => changed = false, 900)"
>
  <div
    class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition duration-500"
    :class="changed ? 'scale-[1.01] ring-4 ring-blue-100' : 'scale-100 ring-0'"
  >
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Event Status</p>
        <span class="mt-2 inline-flex items-center rounded-full border px-3 py-1 text-sm font-bold capitalize <%= statusStyles[event.status] ?? statusStyles.past %>">
          <%= event.status %>
        </span>
      </div>

      <% if (canManage) { %>
        <a
          href="/events/<%= event.id %>/edit"
          class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 no-underline shadow-sm hover:bg-slate-50"
        >
          Edit Event
        </a>
      <% } %>
    </div>

    <% if (errorMessage) { %>
      <div class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800" role="alert">
        <%= errorMessage %>
      </div>
    <% } %>

    <% if (canManage && event.status === "draft") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/publish"
        hx-post="/events/<%= event.id %>/publish"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
        class="mt-4"
      >
        <button
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-emerald-700 sm:w-auto"
        >
          Publish Event
        </button>
      </form>
    <% } else if (canManage && event.status === "published") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/cancel"
        hx-post="/events/<%= event.id %>/cancel"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
        class="mt-4"
      >
        <button
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-rose-700 sm:w-auto"
        >
          Cancel Event
        </button>
      </form>
    <% } else if (canManage && event.status === "cancelled") { %>
      <p class="mt-4 text-sm text-slate-600">This event has been cancelled and cannot be restored.</p>
    <% } else if (canManage && event.status === "past") { %>
      <p class="mt-4 text-sm text-slate-600">This event has already concluded.</p>
    <% } else { %>
      <p class="mt-4 text-sm text-slate-500">No publishing or cancellation actions are available for your role.</p>
    <% } %>
  </div>
</section>
