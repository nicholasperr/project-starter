<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>

<% const statusStyles = {
  draft: "border-yellow-300 text-yellow-300",
  published: "border-green-400 text-green-300",
  cancelled: "border-red-400 text-red-300",
  past: "border-slate-400 text-slate-300"
}; %>

<section
  id="event-lifecycle-panel"
  class="rounded-xl border border-cyan-300/70 bg-slate-950/70 p-5"
  x-data="{ changed: false }"
  x-init="changed = true; setTimeout(() => changed = false, 900)"
>
  <div
    class="transition duration-500"
    :class="changed ? 'scale-[1.02]' : 'scale-100'"
  >
    <h2 class="evently-hand text-3xl font-bold text-cyan-100">Status</h2>

    <span class="mt-3 inline-flex rounded border px-3 py-1 evently-hand text-xl font-bold capitalize <%= statusStyles[event.status] ?? statusStyles.past %>">
      <%= event.status %>
    </span>

    <% if (errorMessage) { %>
      <div class="mt-4 rounded-lg border border-red-400 bg-red-950/40 px-4 py-3 text-sm font-bold text-red-200" role="alert">
        <%= errorMessage %>
      </div>
    <% } %>

    <% if (canManage && event.status === "draft") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/publish"
        hx-post="/events/<%= event.id %>/publish"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
        class="mt-4"
      >
        <button
          type="submit"
          class="evently-hand evently-button-glow w-full rounded-lg border border-cyan-300 bg-slate-900 px-4 py-2 text-xl font-bold text-cyan-100 hover:bg-cyan-950"
        >
          Publish Event
        </button>
      </form>
    <% } else if (canManage && event.status === "published") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/cancel"
        hx-post="/events/<%= event.id %>/cancel"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
        class="mt-4"
      >
        <button
          type="submit"
          class="evently-hand evently-pink-glow w-full rounded-lg border border-pink-400 bg-slate-900 px-4 py-2 text-xl font-bold text-pink-300 hover:bg-pink-950/40"
        >
          Cancel Event
        </button>
      </form>
    <% } else if (canManage && event.status === "cancelled") { %>
      <p class="mt-4 text-sm text-cyan-100/70">This event has been cancelled and cannot be restored.</p>
    <% } else if (canManage && event.status === "past") { %>
      <p class="mt-4 text-sm text-cyan-100/70">This event has already concluded.</p>
    <% } else { %>
      <p class="mt-4 text-sm text-cyan-100/70">No lifecycle actions are available for your role.</p>
    <% } %>
  </div>
</section>