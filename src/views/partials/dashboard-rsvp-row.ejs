<%
  const statusLabel =
    item.event.status === "cancelled"
      ? "event cancelled"
      : item.rsvp.status === "cancelled"
        ? "RSVP cancelled"
        : item.rsvp.status;

  const statusClass =
    item.event.status === "cancelled" || item.rsvp.status === "cancelled"
      ? "border-[#B91717] text-red-300"
      : item.rsvp.status === "waitlisted"
        ? "border-yellow-300 text-yellow-300"
        : "border-green-300 text-green-300";

  const canCancelFromDashboard =
    session.authenticatedUser &&
    session.authenticatedUser.role === "user" &&
    item.event.status !== "cancelled" &&
    item.event.status !== "past" &&
    item.rsvp.status !== "cancelled";

  const canReRsvpFromDashboard =
    session.authenticatedUser &&
    session.authenticatedUser.role === "user" &&
    item.event.status !== "cancelled" &&
    item.event.status !== "past" &&
    item.rsvp.status === "cancelled";
%>

<article
  id="dashboard-rsvp-<%= item.event.id %>"
  class="rounded-xl border border-[#7ec0ce]/50 bg-[#16213e] p-4 transition-colors hover:border-[#7ec0ce]"
>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <a
        href="/events/<%= item.event.id %>"
        class="text-xl font-bold text-[#f1f1f1] no-underline hover:text-[#df3a9e]"
      >
        <%= item.event.title %>
      </a>

      <p class="mt-1 text-sm text-[#7ec0ce]">
        <%= item.event.location %>
      </p>
    </div>

    <span class="inline-flex w-fit rounded-full border px-3 py-1 text-xs font-bold capitalize <%= statusClass %>">
      <%= statusLabel %>
    </span>
  </div>

  <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
    <div class="rounded-lg bg-[#0d1525] p-3">
      <p class="font-bold text-[#7ec0ce]">Start</p>
      <p class="text-[#f1f1f1]"><%= item.event.startDatetime.toLocaleString() %></p>
    </div>

    <div class="rounded-lg bg-[#0d1525] p-3">
      <p class="font-bold text-[#7ec0ce]">End</p>
      <p class="text-[#f1f1f1]"><%= item.event.endDatetime.toLocaleString() %></p>
    </div>

    <div class="rounded-lg bg-[#0d1525] p-3">
      <p class="font-bold text-[#7ec0ce]">Category</p>
      <p class="capitalize text-[#f1f1f1]"><%= item.event.category %></p>
    </div>

    <div class="rounded-lg bg-[#0d1525] p-3">
      <p class="font-bold text-[#7ec0ce]">Capacity</p>
      <p class="text-[#f1f1f1]"><%= item.event.capacity === null ? "No limit" : item.event.capacity %></p>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-3">
    <a
      href="/events/<%= item.event.id %>"
      class="text-sm font-bold text-[#4685FF] no-underline hover:text-[#7ec0ce]"
    >
      View Event
    </a>

    <% if (canCancelFromDashboard) { %>
      <form
        method="POST"
        action="/events/<%= item.event.id %>/rsvp"
        hx-post="/events/<%= item.event.id %>/rsvp"
        hx-target="#dashboard-content"
        hx-swap="outerHTML"
        x-data="{ confirmCancel: false }"
        x-on:submit.prevent="
          if (confirmCancel) {
            $el.submit();
          } else {
            confirmCancel = true;
            setTimeout(() => confirmCancel = false, 2500);
          }
        "
      >
        <input type="hidden" name="context" value="dashboard" />
        <button
          type="submit"
          class="rounded-lg bg-[#df3a9e] px-4 py-2 text-sm font-bold text-[#f1f1f1] hover:bg-[#d12c90]"
        >
          <span x-show="!confirmCancel">
            <% if (item.rsvp.status === "waitlisted") { %>
              Leave Waitlist
            <% } else { %>
              Cancel RSVP
            <% } %>
          </span>
          <span x-show="confirmCancel">Click again to confirm</span>
        </button>
      </form>
    <% } else if (canReRsvpFromDashboard) { %>
      <form
        method="POST"
        action="/events/<%= item.event.id %>/rsvp"
        hx-post="/events/<%= item.event.id %>/rsvp"
        hx-target="#dashboard-content"
        hx-swap="outerHTML"
      >
        <input type="hidden" name="context" value="dashboard" />
        <button
          type="submit"
          class="rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#7ec0ce] px-4 py-2 text-sm font-bold hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
        >
          RSVP Again
        </button>
      </form>
    <% } else if (item.event.status === "cancelled") { %>
      <p class="text-sm text-red-300">This event was cancelled.</p>
    <% } %>
  </div>
</article>