<% if (events.length === 0) { %>
    <p class="text-[#7ec0ce]">No events found.</p>
  <% } else { %>
    <ul class="space-y-4 rounded-2xl border-2 border-[#7ec0ce] bg-[#0d1525] p-5">
      <% events.forEach(event => { %>
        <li class="p-4 border border-[#7ec0ce]/40 rounded-xl bg-[#16213e] hover:border-[#7ec0ce] transition-colors">
          <a href="/events/<%= event.id %>" class="text-lg font-semibold text-[#4685FF] hover:text-[#7ec0ce] hover:underline"><%= event.title %></a>
          <p class="text-sm text-[#7ec0ce] mt-1"><%= event.location %> &middot; <%= event.startDatetime.toLocaleDateString() %> <%= event.startDatetime.toLocaleTimeString() %></p>
          <p class="text-sm text-[#f1f1f1]/70 mt-1"><%= event.description %></p>
          <span class="text-xs text-[#7ec0ce]/60"><%= event.category %></span>
        </li>
      <% }) %>
    </ul>
  <% } %>
