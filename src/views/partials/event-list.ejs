<% if (events.length === 0) { %>
    <p class="text-[#7ec0ce]">No events found.</p>
  <% } else { %>
    <ul class="space-y-4 ">
      <% events.forEach(event => { %>
        <li class="p-3 border border-[#7ec0ce]/40 rounded-xl bg-[#0d1525] hover:border-[#7ec0ce] transition-colors">
          <a href="/events/<%= event.id %>" class="text-2xl font-semibold text-[#FF41B5] hover:text-[#d12490] hover:underline"><%= event.title %></a>
          <p class="text-sm text-[#7ec0ce] mt-1"><%= event.location %> &middot; <%= event.startDatetime.toLocaleDateString() %> <%= event.startDatetime.toLocaleTimeString() %></p>
          <p class="text-sm text-[#f1f1f1]/70 mt-1"><%= event.description %></p>
          <span class="text-xs text-[#7ec0ce]/60"><%= event.category %></span>
        </li>
      <% }) %>
    </ul>
  <% } %>
