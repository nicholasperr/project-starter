<div id="lifecycle-controls" class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-lg font-semibold mb-3">Actions</h2>

  <% const user = session.authenticatedUser; %>
  <% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>

  <div class="mb-3">
    <span
      class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium border border-slate-200 bg-slate-50 text-slate-700"
      id="status-badge"
    >
      <%= event.status %>
    </span>
  </div>

  <% if (canManage && event.status === "draft") { %>
    <form
      method="POST"
      action="/events/<%= event.id %>/publish"
      hx-post="/events/<%= event.id %>/publish"
      hx-target="#lifecycle-controls"
      hx-swap="outerHTML"
      class="mb-3"
    >
      <button
        type="submit"
        class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium cursor-pointer hover:bg-green-700"
      >
        Publish
      </button>
    </form>
  <% } %>

  <% if (canManage && event.status === "published") { %>
    <form
      method="POST"
      action="/events/<%= event.id %>/cancel"
      hx-post="/events/<%= event.id %>/cancel"
      hx-target="#lifecycle-controls"
      hx-swap="outerHTML"
      class="mb-3"
    >
      <button
        type="submit"
        class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium cursor-pointer hover:bg-red-700"
      >
        Cancel event
      </button>
    </form>
  <% } %>

  <% if (!canManage && user && user.role === "user") { %>
    <form method="POST" action="/events/<%= event.id %>/rsvp" class="mb-3">
      <button
        type="submit"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
      >
        RSVP
      </button>
    </form>
  <% } %>
</div>