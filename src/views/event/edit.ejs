<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>

<%
  const statusClass =
    (formValues?.status ?? event.status) === "published"
      ? "border-green-300 text-green-300"
      : (formValues?.status ?? event.status) === "draft"
        ? "border-yellow-300 text-yellow-300"
        : (formValues?.status ?? event.status) === "cancelled"
          ? "border-red-300 text-red-300"
          : "border-[#7ec0ce] text-[#7ec0ce]";
%>

<form action="/events/<%= event.id %>" method="post" class="space-y-6">
  <div class="mb-6 rounded-2xl bg-[#16213e] p-6 shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce] border-2 border-[white]">
    <h1 class="text-4xl font-bold text-[#f1f1f1] mb-2"><%= pageTitle %></h1>
    <p class="text-[#9bb7d4]">Update the event details below and save your changes.</p>
  </div>
  <section class="mb-5 p-6 border-2 border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex-1">
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-[#7ec0ce]">
          Event Detail
        </p>

        <label class="block mt-3">
          <span class="text-sm font-bold text-[#7ec0ce] mb-2 block">Title</span>
          <input
            type="text"
            name="title"
            value="<%= formValues?.title ?? event.title %>"
            class="w-full rounded-lg bg-[#0c1a35] border border-[#33527c] text-[#f1f1f1] px-4 py-2 text-4xl font-bold focus:border-[#7ec0ce] focus:outline-none"
            required
          />
          <%- include('../partials/field-error', { message: errors?.title }) %>
        </label>

        <label class="block mt-3">
          <span class="text-sm font-bold text-[#7ec0ce] mb-2 block">Description</span>
          <textarea
            name="description"
            rows="4"
            class="w-full rounded-lg bg-[#0c1a35] border border-[#33527c] text-[#9bb7d4] px-4 py-2 focus:border-[#7ec0ce] focus:outline-none"
            required
          ><%= formValues?.description ?? event.description %></textarea>
          <%- include('../partials/field-error', { message: errors?.description }) %>
        </label>
      </div>

      <div class="flex flex-col gap-2">
        <span class="text-sm font-bold text-[#7ec0ce]">Status</span>
        <select
          name="status"
          class="rounded-full border px-4 py-1 text-sm font-bold capitalize <%= statusClass %> bg-[#16213e] focus:outline-none"
        >
          <option value="draft" <%= ((formValues?.status ?? event.status) === 'draft') ? 'selected' : '' %>>draft</option>
          <option value="published" <%= ((formValues?.status ?? event.status) === 'published') ? 'selected' : '' %>>published</option>
          <option value="cancelled" <%= ((formValues?.status ?? event.status) === 'cancelled') ? 'selected' : '' %>>cancelled</option>
          <option value="past" <%= ((formValues?.status ?? event.status) === 'past') ? 'selected' : '' %>>past</option>
        </select>
        <%- include('../partials/field-error', { message: errors?.status }) %>
      </div>
    </div>
  </section>

  <section class="grid gap-6 lg:grid-cols-[1fr_0.95fr]">
    <section class="rounded-2xl border-2 border-[white] bg-[#16213e] p-6 shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
      <h2 class="mb-5 text-2xl font-bold text-[#f1f1f1]">
        Details
      </h2>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <span class="font-bold text-[#7ec0ce]">Location</span>
          <input
            type="text"
            name="location"
            value="<%= formValues?.location ?? event.location %>"
            class="mt-1 w-full bg-transparent text-[#f1f1f1] border-none focus:outline-none"
            required
          />
          <%- include('../partials/field-error', { message: errors?.location }) %>
        </label>

        <label class="block rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <span class="font-bold text-[#7ec0ce]">Category</span>
          <select
            name="category"
            class="mt-1 w-full bg-transparent text-[#f1f1f1] border-none focus:outline-none capitalize"
            required
          >
            <option value="music" <%= ((formValues?.category ?? event.category) === 'music') ? 'selected' : '' %>>music</option>
            <option value="sports" <%= ((formValues?.category ?? event.category) === 'sports') ? 'selected' : '' %>>sports</option>
            <option value="technology" <%= ((formValues?.category ?? event.category) === 'technology') ? 'selected' : '' %>>technology</option>
            <option value="art" <%= ((formValues?.category ?? event.category) === 'art') ? 'selected' : '' %>>art</option>
            <option value="education" <%= ((formValues?.category ?? event.category) === 'education') ? 'selected' : '' %>>education</option>
            <option value="health" <%= ((formValues?.category ?? event.category) === 'health') ? 'selected' : '' %>>health</option>
            <option value="business" <%= ((formValues?.category ?? event.category) === 'business') ? 'selected' : '' %>>business</option>
            <option value="food" <%= ((formValues?.category ?? event.category) === 'food') ? 'selected' : '' %>>food</option>
            <option value="other" <%= ((formValues?.category ?? event.category) === 'other') ? 'selected' : '' %>>other</option>
          </select>
          <%- include('../partials/field-error', { message: errors?.category }) %>
        </label>

        <label class="block rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <span class="font-bold text-[#7ec0ce]">Starts</span>
          <input
            type="datetime-local"
            name="startDatetime"
            value="<%= formValues?.startDatetime ?? (() => {
              const d = new Date(event.startDatetime);
              const year = d.getFullYear();
              const month = String(d.getMonth() + 1).padStart(2, '0');
              const day = String(d.getDate()).padStart(2, '0');
              const hours = String(d.getHours()).padStart(2, '0');
              const minutes = String(d.getMinutes()).padStart(2, '0');
              return `${year}-${month}-${day}T${hours}:${minutes}`;
            })() %>"
            class="mt-1 w-full bg-transparent text-[#f1f1f1] border-none focus:outline-none"
            required
          />
          <%- include('../partials/field-error', { message: errors?.startDatetime }) %>
        </label>

        <label class="block rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <span class="font-bold text-[#7ec0ce]">Ends</span>
          <input
            type="datetime-local"
            name="endDatetime"
            value="<%= formValues?.endDatetime ?? (() => {
              const d = new Date(event.endDatetime);
              const year = d.getFullYear();
              const month = String(d.getMonth() + 1).padStart(2, '0');
              const day = String(d.getDate()).padStart(2, '0');
              const hours = String(d.getHours()).padStart(2, '0');
              const minutes = String(d.getMinutes()).padStart(2, '0');
              return `${year}-${month}-${day}T${hours}:${minutes}`;
            })() %>"
            class="mt-1 w-full bg-transparent text-[#f1f1f1] border-none focus:outline-none"
            required
          />
          <%- include('../partials/field-error', { message: errors?.endDatetime }) %>
        </label>

        <label class="block rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <span class="font-bold text-[#7ec0ce]">Capacity</span>
          <input
            type="number"
            name="capacity"
            value="<%= formValues?.capacity ?? (event.capacity ?? '') %>"
            class="mt-1 w-full bg-transparent text-[#f1f1f1] border-none focus:outline-none"
            placeholder="No limit"
          />
          <%- include('../partials/field-error', { message: errors?.capacity }) %>
        </label>

        <div class="rounded-2xl border border-[#33527c] bg-[#0c1a35] p-4">
          <dt class="font-bold text-[#7ec0ce]">Organizer</dt>
          <dd class="mt-1 break-words text-[#f1f1f1]"><%= organizerName %></dd>
        </div>
      </div>
    </section>

    <section class="rounded-2xl border-2 border-[white] bg-[#16213e] p-6 shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
      <h2 class="mb-5 text-2xl font-bold text-[#f1f1f1]">
        Actions
      </h2>

      <div class="space-y-4">
        <button
          type="submit"
          class="w-full rounded-lg bg-[#df3a9e] text-[#f1f1f1] px-4 py-2 font-bold hover:bg-[#d12c90]"
        >
          Save Event
        </button>

        <a
          href="/events/<%= event.id %>"
          class="inline-flex w-full items-center justify-center rounded-lg border-2 border-[#df3a9e] text-[#df3a9e] px-4 py-2 font-bold no-underline hover:bg-[#242945]"
        >
          Cancel Edit
        </a>
      </div>
    </section>
  </section>
</form>

<section class="mt-8 flex justify-center">
  <a
    href="/events"
    class="inline-flex items-center justify-center rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#e6faff] px-8 py-3 text-lg font-bold no-underline hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
  >
    BACK TO EVENTS
  </a>
</section>
