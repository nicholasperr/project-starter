<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-2">
        Event Detail
      </p>
      <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event.title %></h1>
      <p class="text-slate-500"><%= event.description %></p>
    </div>

    <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium border border-slate-200 bg-slate-50 text-slate-700">
      <%= event.status %>
    </span>
  </div>
</section>

<section class="grid gap-4 md:grid-cols-2">
  <div class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <h2 class="text-lg font-semibold mb-3">Details</h2>

    <dl class="space-y-2 text-slate-700">
      <div>
        <dt class="font-medium">Location</dt>
        <dd><%= event.location %></dd>
      </div>

      <div>
        <dt class="font-medium">Category</dt>
        <dd><%= event.category %></dd>
      </div>

      <div>
        <dt class="font-medium">Starts</dt>
        <dd><%= event.startDatetime.toLocaleString() %></dd>
      </div>

      <div>
        <dt class="font-medium">Ends</dt>
        <dd><%= event.endDatetime.toLocaleString() %></dd>
      </div>

      <div>
        <dt class="font-medium">Capacity</dt>
        <dd><%= event.capacity === null ? "No limit" : event.capacity %></dd>
      </div>

      <div>
        <dt class="font-medium">Organizer ID</dt>
        <dd><%= event.organizerId %></dd>
      </div>
    </dl>
  </div>

  <%- include("partials/lifecycle-controls", { event, session }) %>
</section>
