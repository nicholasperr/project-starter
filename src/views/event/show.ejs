<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>

<%
  const statusClass =
    event.status === "published"
      ? "border-green-300 text-green-300"
      : event.status === "draft"
        ? "border-yellow-300 text-yellow-300"
        : event.status === "cancelled"
          ? "border-red-300 text-red-300"
          : "border-[#7ec0ce] text-[#7ec0ce]";
%>

<section class="mb-5 p-6 border-2 border-[white] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.16em] text-[#7ec0ce]">
        Event Detail
      </p>

      <h1 class="mt-3 text-4xl font-bold text-[#f1f1f1]">
        <%= event.title %>
      </h1>

      <p class="mt-3 max-w-3xl text-[#9bb7d4]">
        <%= event.description %>
      </p>
    </div>

    <span class="inline-flex w-fit rounded-full border px-4 py-1 text-sm font-bold capitalize <%= statusClass %>">
      <%= event.status %>
    </span>
  </div>
</section>

<section class="grid gap-6 lg:grid-cols-[1fr_0.95fr]">
  <section class="rounded-2xl border-2 border-[white] bg-[#16213e] p-6 shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
    <h2 class="mb-5 text-2xl font-bold text-[#f1f1f1]">
      Details
    </h2>

    <dl class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Location</dt>
        <dd class="mt-1 text-[#f1f1f1]"><%= event.location %></dd>
      </div>

      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Category</dt>
        <dd class="mt-1 capitalize text-[#f1f1f1]"><%= event.category %></dd>
      </div>

      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Starts</dt>
        <dd class="mt-1 text-[#f1f1f1]"><%= event.startDatetime.toLocaleString() %></dd>
      </div>

      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Ends</dt>
        <dd class="mt-1 text-[#f1f1f1]"><%= event.endDatetime.toLocaleString() %></dd>
      </div>

      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Capacity</dt>
        <dd class="mt-1 text-[#f1f1f1]"><%= event.capacity === null ? "No limit" : event.capacity %></dd>
      </div>

      <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-4">
        <dt class="font-bold text-[#7ec0ce]">Organizer</dt>
        <dd class="mt-1 break-words text-[#f1f1f1]"><%= organizerName %></dd>
      </div>    
    </dl>
  </section>

  <section class="rounded-2xl border-2 border-[white] bg-[#16213e] p-6 shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_12px_#7ec0ce,0_0_20px_#7ec0ce]">
    <h2 class="mb-5 text-2xl font-bold text-[#f1f1f1]">
      Actions
    </h2>

    <div class="rounded-2xl border border-[#21325c] bg-[#0c1a35] p-5">
      <div id="rsvp-action">
        <%- include("../partials/rsvp-action", { event, session, currentRsvp, errorMessage }) %>
      </div>

      <% if (canManage && event.status === "draft") { %>
        <form method="POST" action="/events/<%= event.id %>/publish" class="mt-4">
          <button
            type="submit"
            class="w-full rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#e6faff] px-4 py-2 font-bold hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
          >
            Publish Event
          </button>
        </form>
      <% } %>

      <% if (canManage && event.status === "published") { %>
        <form method="POST" action="/events/<%= event.id %>/cancel" class="mt-4">
          <button
            type="submit"
            class="w-full rounded-lg bg-[#df3a9e] px-4 py-2 font-bold text-[#f1f1f1] hover:bg-[#d12c90]"
          >
            Cancel Event
          </button>
        </form>
      <% } %>

      <% if (canManage) { %>
        <a
          href="/events/<%= event.id %>/edit"
          class="mt-4 inline-flex w-full items-center justify-center rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#e6faff] px-4 py-2 font-bold no-underline hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
        >
          Edit Event
        </a>
      <% } %>

      <% if (!canManage && (!user || user.role !== "user")) { %>
        <p class="mt-3 text-sm text-[#9bb7d4]">
          No actions available for your role.
        </p>
      <% } %>
    </div>
  </section>
</section>

<section class="mt-8 flex justify-center">
  <a
    href="/events"
    class="inline-flex items-center justify-center rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#e6faff] px-8 py-3 text-lg font-bold no-underline hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
  >
    BACK TO EVENTS
  </a>
</section>