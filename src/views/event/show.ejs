<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>
<% const capacityLabel = event.capacity === null ? "No limit" : event.capacity; %>
<% const attendanceLabel = event.capacity === null ? `${goingCount} attending` : `${goingCount} / ${event.capacity} attending`; %>

<section class="space-y-6">
  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-lg">
    <div class="border-b border-slate-200 bg-gradient-to-r from-blue-50 via-white to-slate-50 p-6 sm:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-700">
            Event Detail
          </p>
          <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
            <%= event.title %>
          </h1>
          <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">
            <%= event.description %>
          </p>
        </div>

        <div class="shrink-0">
          <%- include("../partials/event-lifecycle-panel", { event, session, errorMessage: null }) %>
        </div>
      </div>
    </div>

    <div class="grid gap-6 p-6 sm:p-8 lg:grid-cols-[1.4fr_0.8fr]">
      <div class="space-y-6">
        <section class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <h2 class="text-xl font-bold text-slate-900">When and where</h2>

          <dl class="mt-4 grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl bg-white p-4 shadow-sm">
              <dt class="text-sm font-semibold text-slate-500">Starts</dt>
              <dd
                class="mt-1 text-slate-900"
                x-data="{
                  date: new Date('<%= event.startDatetime.toISOString() %>'),
                  label: '',
                  updateLabel() {
                    const now = new Date();
                    const diffMs = this.date - now;
                    const diffDays = Math.round(diffMs / 86400000);

                    if (diffDays === 0) {
                      this.label = 'today';
                    } else if (diffDays === 1) {
                      this.label = 'tomorrow';
                    } else if (diffDays === -1) {
                      this.label = 'yesterday';
                    } else if (diffDays > 1) {
                      this.label = `in ${diffDays} days`;
                    } else {
                      this.label = `${Math.abs(diffDays)} days ago`;
                    }
                  }
                }"
                x-init="updateLabel()"
              >
                <span class="block font-semibold"><%= event.startDatetime.toLocaleString() %></span>
                <span class="mt-1 inline-flex rounded-full bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700" x-text="label"></span>
              </dd>
            </div>

            <div class="rounded-xl bg-white p-4 shadow-sm">
              <dt class="text-sm font-semibold text-slate-500">Ends</dt>
              <dd class="mt-1 font-semibold text-slate-900"><%= event.endDatetime.toLocaleString() %></dd>
            </div>

            <div class="rounded-xl bg-white p-4 shadow-sm">
              <dt class="text-sm font-semibold text-slate-500">Location</dt>
              <dd class="mt-1 font-semibold text-slate-900"><%= event.location %></dd>
            </div>

            <div class="rounded-xl bg-white p-4 shadow-sm">
              <dt class="text-sm font-semibold text-slate-500">Category</dt>
              <dd class="mt-1 font-semibold capitalize text-slate-900"><%= event.category %></dd>
            </div>
          </dl>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Attendance</h2>

          <div class="mt-4 grid gap-4 sm:grid-cols-3">
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-500">Current RSVPs</p>
              <p class="mt-1 text-2xl font-black text-slate-950"><%= goingCount %></p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-500">Capacity</p>
              <p class="mt-1 text-2xl font-black text-slate-950"><%= capacityLabel %></p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-500">Summary</p>
              <p class="mt-1 text-base font-bold text-slate-950"><%= attendanceLabel %></p>
            </div>
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">Organizer</h2>
          <p class="mt-3 break-words rounded-xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
            <%= event.organizerId %>
          </p>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">RSVP</h2>
          <div class="mt-4">
            <%- include("../partials/rsvp-action", { event, session, currentRsvp, errorMessage }) %>
          </div>
        </section>

        <% if (!canManage && (!user || user.role !== "user")) { %>
          <section class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-600">
            No actions are available for your role.
          </section>
        <% } %>
      </aside>
    </div>
  </div>

  <div>
    <a href="/events" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 no-underline shadow-sm hover:bg-slate-50">
      Back to events
    </a>
  </div>
</section>
