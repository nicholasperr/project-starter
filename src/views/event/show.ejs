<% const user = session.authenticatedUser; %>
<% const canManage = user && (user.role === "admin" || user.userId === event.organizerId); %>
<% const capacityLabel = event.capacity === null ? "No limit" : event.capacity; %>
<% const attendanceLabel = event.capacity === null ? `${goingCount} attending` : `${goingCount} / ${event.capacity} attending`; %>

<section class="evently-card rounded-2xl border border-cyan-300/70 bg-slate-900/80 p-6">
  <div class="mb-6 text-center">
    <h1 class="evently-hand evently-glow text-5xl font-bold tracking-widest text-pink-200">EVENTLY</h1>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr]">
    <section class="rounded-xl border border-cyan-300/70 bg-slate-950/70 p-5">
      <div class="mb-5 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="evently-hand text-2xl font-bold text-cyan-200">Event Details</p>
          <h2 class="evently-hand mt-2 text-4xl font-bold text-white"><%= event.title %></h2>
          <p class="mt-3 text-cyan-100/75"><%= event.description %></p>
        </div>
      </div>

      <dl class="grid gap-3 md:grid-cols-2">
        <div class="rounded-lg bg-slate-900 p-4">
          <dt class="evently-hand text-xl font-bold text-cyan-300">Location</dt>
          <dd class="mt-1 text-white"><%= event.location %></dd>
        </div>

        <div class="rounded-lg bg-slate-900 p-4">
          <dt class="evently-hand text-xl font-bold text-cyan-300">Category</dt>
          <dd class="mt-1 capitalize text-white"><%= event.category %></dd>
        </div>

        <div
          class="rounded-lg bg-slate-900 p-4"
          x-data="{
            date: new Date('<%= event.startDatetime.toISOString() %>'),
            label: '',
            updateLabel() {
              const now = new Date();
              const diffMs = this.date - now;
              const diffDays = Math.round(diffMs / 86400000);

              if (diffDays === 0) {
                this.label = 'today';
              } else if (diffDays === 1) {
                this.label = 'tomorrow';
              } else if (diffDays === -1) {
                this.label = 'yesterday';
              } else if (diffDays > 1) {
                this.label = `in ${diffDays} days`;
              } else {
                this.label = `${Math.abs(diffDays)} days ago`;
              }
            }
          }"
          x-init="updateLabel()"
        >
          <dt class="evently-hand text-xl font-bold text-cyan-300">Start</dt>
          <dd class="mt-1 text-white"><%= event.startDatetime.toLocaleString() %></dd>
          <dd class="mt-2 evently-hand text-lg font-bold text-pink-300" x-text="label"></dd>
        </div>

        <div class="rounded-lg bg-slate-900 p-4">
          <dt class="evently-hand text-xl font-bold text-cyan-300">End</dt>
          <dd class="mt-1 text-white"><%= event.endDatetime.toLocaleString() %></dd>
        </div>

        <div class="rounded-lg bg-slate-900 p-4">
          <dt class="evently-hand text-xl font-bold text-cyan-300">Capacity</dt>
          <dd class="mt-1 text-white"><%= capacityLabel %></dd>
        </div>

        <div class="rounded-lg bg-slate-900 p-4">
          <dt class="evently-hand text-xl font-bold text-cyan-300">Attendance</dt>
          <dd class="mt-1 text-white"><%= attendanceLabel %></dd>
        </div>
      </dl>
    </section>

    <aside class="space-y-6">
      <%- include("../partials/event-lifecycle-panel", { event, session, errorMessage: null }) %>

      <section class="rounded-xl border border-cyan-300/70 bg-slate-950/70 p-5">
        <h2 class="evently-hand text-3xl font-bold text-cyan-100">Organizer</h2>
        <p class="mt-3 break-words rounded-lg bg-slate-900 p-3 text-sm text-cyan-100/80">
          <%= event.organizerId %>
        </p>
      </section>

      <section class="rounded-xl border border-cyan-300/70 bg-slate-950/70 p-5">
        <h2 class="evently-hand text-3xl font-bold text-cyan-100">RSVP</h2>
        <div class="mt-4">
          <%- include("../partials/rsvp-action", { event, session, currentRsvp, errorMessage }) %>
        </div>
      </section>
    </aside>
  </div>

  <div class="mt-8 flex flex-wrap justify-center gap-4">
    <a
      href="/events"
      class="evently-hand rounded-lg border border-pink-400 px-5 py-2 text-xl font-bold text-pink-300 no-underline hover:bg-pink-500/10"
    >
      View All Events
    </a>

    <% if (canManage) { %>
      <a
        href="/events/<%= event.id %>/edit"
        class="evently-hand evently-button-glow rounded-lg border border-cyan-300 bg-slate-900 px-5 py-2 text-xl font-bold text-cyan-100 no-underline hover:bg-cyan-950"
      >
        Edit Event
      </a>
    <% } %>
  </div>
</section>