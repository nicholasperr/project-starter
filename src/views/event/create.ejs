<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h1 class="text-2xl font-bold mb-4"><%= pageTitle %></h1>
  
  <% if (pageError) { %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded text-red-700">
      <%= pageError %>
    </div>
  <% } %>
  
  <form action="/events" method="post" class="space-y-4">
    <label class="block">
      <span class="text-slate-700">Title</span>
      <input type="text" name="title" value="<%= formValues?.title ?? '' %>" class="mt-1 block w-full border rounded p-2" required />
      <%- include('../partials/field-error', { message: errors?.title }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Description</span>
      <textarea name="description" class="mt-1 block w-full border rounded p-2" rows="4" required><%= formValues?.description ?? '' %></textarea>
      <%- include('../partials/field-error', { message: errors?.description }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Location</span>
      <input type="text" name="location" value="<%= formValues?.location ?? '' %>" class="mt-1 block w-full border rounded p-2" required />
      <%- include('../partials/field-error', { message: errors?.location }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Category</span>
      <select name="category" class="mt-1 block w-full border rounded p-2" required>
        <option value="music" <%= (formValues?.category ?? '') === 'music' ? 'selected' : '' %>>music</option>
        <option value="sports" <%= (formValues?.category ?? '') === 'sports' ? 'selected' : '' %>>sports</option>
        <option value="technology" <%= (formValues?.category ?? '') === 'technology' ? 'selected' : '' %>>technology</option>
        <option value="art" <%= (formValues?.category ?? '') === 'art' ? 'selected' : '' %>>art</option>
        <option value="education" <%= (formValues?.category ?? '') === 'education' ? 'selected' : '' %>>education</option>
        <option value="health" <%= (formValues?.category ?? '') === 'health' ? 'selected' : '' %>>health</option>
        <option value="business" <%= (formValues?.category ?? '') === 'business' ? 'selected' : '' %>>business</option>
        <option value="food" <%= (formValues?.category ?? '') === 'food' ? 'selected' : '' %>>food</option>
        <option value="other" <%= (formValues?.category ?? '') === 'other' ? 'selected' : '' %>>other</option>
      </select>
      <%- include('../partials/field-error', { message: errors?.category }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Status</span>
      <select name="status" class="mt-1 block w-full border rounded p-2">
        <option value="draft" <%= (formValues?.status ?? '') === 'draft' ? 'selected' : '' %>>draft</option>
        <option value="published" <%= (formValues?.status ?? '') === 'published' ? 'selected' : '' %>>published</option>
        <option value="cancelled" <%= (formValues?.status ?? '') === 'cancelled' ? 'selected' : '' %>>cancelled</option>
        <option value="past" <%= (formValues?.status ?? '') === 'past' ? 'selected' : '' %>>past</option>
      </select>
      <%- include('../partials/field-error', { message: errors?.status }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Capacity</span>
      <input type="number" name="capacity" value="<%= formValues?.capacity ?? '' %>" class="mt-1 block w-full border rounded p-2" />
      <%- include('../partials/field-error', { message: errors?.capacity }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">Start</span>
      <input type="datetime-local" name="startDatetime" value="<%= formValues?.startDatetime ?? '' %>" class="mt-1 block w-full border rounded p-2" required />
      <%- include('../partials/field-error', { message: errors?.startDatetime }) %>
    </label>

    <label class="block">
      <span class="text-slate-700">End</span>
      <input type="datetime-local" name="endDatetime" value="<%= formValues?.endDatetime ?? '' %>" class="mt-1 block w-full border rounded p-2" required />
      <%- include('../partials/field-error', { message: errors?.endDatetime }) %>
    </label>

    <input type="hidden" name="organizerId" value="<%= formValues?.organizerId ?? session.authenticatedUser.userId %>" />

    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded">Create Event</button>
  </form>
</section>
