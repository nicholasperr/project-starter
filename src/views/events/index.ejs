<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-4">Events</h1>

  <form method="GET" action="/events/search" class="mb-4 flex gap-2">
    <input
      type="text"
      name="query"
      value="<%= query ?? '' %>"
      placeholder="Search events..."
      hx-get="/events/search"
      hx-target="#event-list"
      hx-swap="innerHTML"
      hx-push-url="true"
      hx-trigger="keyup changed delay:300ms"
      class="flex-1 border border-slate-300 rounded-lg px-3 py-2 text-sm"
    />
  </form>

  <form method="GET" action="/events" hx-get="/events" hx-target="#event-list" hx-swap="innerHTML" hx-push-url="true" class="flex gap-3 mb-6">
    <select name="category" class="border border-slate-300 rounded-lg px-3 py-2 text-sm">
      <option value="">All Categories</option>
      <option value="music" <%= category === 'music' ? 'selected' : '' %>>Music</option>
      <option value="sports" <%= category === 'sports' ? 'selected' : '' %>>Sports</option>
      <option value="academic" <%= category === 'academic' ? 'selected' : '' %>>Academic</option>
      <option value="social" <%= category === 'social' ? 'selected' : '' %>>Social</option>
      <option value="food" <%= category === 'food' ? 'selected' : '' %>>Food</option>
      <option value="arts" <%= category === 'arts' ? 'selected' : '' %>>Arts</option>
      <option value="networking" <%= category === 'networking' ? 'selected' : '' %>>Networking</option>
      <option value="other" <%= category === 'other' ? 'selected' : '' %>>Other</option>
    </select>

    <select name="timeframe" class="border border-slate-300 rounded-lg px-3 py-2 text-sm">
      <option value="">All Time</option>
      <option value="all_upcoming" <%= timeframe === 'all_upcoming' ? 'selected' : '' %>>All Upcoming</option>
      <option value="this_week" <%= timeframe === 'this_week' ? 'selected' : '' %>>This Week</option>
      <option value="this_weekend" <%= timeframe === 'this_weekend' ? 'selected' : '' %>>This Weekend</option>
    </select>

    <button type="submit" class="px-4 py-2 bg-slate-700 text-white rounded-lg text-sm hover:bg-slate-800">Filter</button>
  </form>

  <div id="event-list">
  <%- include("../partials/event-list") %>
  </div>
</section>
