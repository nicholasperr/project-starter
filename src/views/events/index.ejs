<section class="mb-5 p-6 border border-[#7ec0ce] rounded-2xl bg-[#16213e] shadow-lg">
  <h1 class="text-3xl font-bold text-[#f1f1f1] mb-4">Events</h1>

  <form method="GET" action="/events/search" class="mb-4 flex gap-2">
    <div
      x-data="{ query: '<%= (query ?? '').replace(/'/g, String.fromCharCode(39)) %>' }"
      class="relative flex-1"
    >
      <input
        type="text"
        name="query"
        x-model="query"
        value="<%= query ?? '' %>"
        placeholder="Search events..."
        hx-get="/events/search"
        hx-target="#event-list"
        hx-swap="innerHTML"
        hx-push-url="true"
        hx-trigger="keyup changed delay:300ms"
        class="w-full border border-[#7ec0ce] rounded-lg px-3 py-2 pr-8 text-sm bg-[#0d1525] text-[#f1f1f1] placeholder-[#7ec0ce]/60 focus:outline-none focus:border-[#4685FF]"
      />
      <button
        x-show="query.length > 0"
        x-on:click="query = ''; $nextTick(() => { $el.closest('form').requestSubmit() })"
        type="button"
        class="absolute right-2 top-1/2 -translate-y-1/2 text-[#7ec0ce] hover:text-[#f1f1f1] text-lg leading-none"
      >&times;</button>
    </div>
  </form>

  <form
    method="GET"
    action="/events"
    hx-get="/events"
    hx-target="#event-list"
    hx-swap="innerHTML"
    hx-push-url="true"
    class="flex gap-3 mb-6 flex-wrap items-center"
    x-data="{ category: '<%= category ?? '' %>', timeframe: '<%= timeframe ?? '' %>' }"
  >
    <select name="category" x-model="category" x-on:change="$el.closest('form').requestSubmit()" class="border border-[#7ec0ce] rounded-lg px-3 py-2 text-sm bg-[#0d1525] text-[#f1f1f1] focus:outline-none focus:border-[#4685FF]">
      <option value="">All Categories</option>
      <option value="music" <%= category === 'music' ? 'selected' : '' %>>Music</option>
      <option value="sports" <%= category === 'sports' ? 'selected' : '' %>>Sports</option>
      <option value="academic" <%= category === 'academic' ? 'selected' : '' %>>Academic</option>
      <option value="social" <%= category === 'social' ? 'selected' : '' %>>Social</option>
      <option value="food" <%= category === 'food' ? 'selected' : '' %>>Food</option>
      <option value="arts" <%= category === 'arts' ? 'selected' : '' %>>Arts</option>
      <option value="networking" <%= category === 'networking' ? 'selected' : '' %>>Networking</option>
      <option value="other" <%= category === 'other' ? 'selected' : '' %>>Other</option>
    </select>

    <select name="timeframe" x-model="timeframe" x-on:change="$el.closest('form').requestSubmit()" class="border border-[#7ec0ce] rounded-lg px-3 py-2 text-sm bg-[#0d1525] text-[#f1f1f1] focus:outline-none focus:border-[#4685FF]">
      <option value="">All Time</option>
      <option value="all_upcoming" <%= timeframe === 'all_upcoming' ? 'selected' : '' %>>All Upcoming</option>
      <option value="this_week" <%= timeframe === 'this_week' ? 'selected' : '' %>>This Week</option>
      <option value="this_weekend" <%= timeframe === 'this_weekend' ? 'selected' : '' %>>This Weekend</option>
    </select>

    <button type="submit" class="px-4 py-2 bg-[#16213e] text-[#7ec0ce] border-2 border-[#7ec0ce] rounded-lg text-sm font-medium cursor-pointer hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]">Filter</button>

    <a
      x-show="category !== '' || timeframe !== ''"
      href="/events"
      class="text-sm text-[#7ec0ce] hover:text-[#f1f1f1] underline"
    >Clear filters</a>
  </form>

  <div id="event-list">
  <%- include("../partials/event-list") %>
  </div>
</section>
