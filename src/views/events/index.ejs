<section class="mb-6 text-center">
  <h1 class="evently-logo text-6xl text-white">EVENTLY</h1>
</section>

<section class="evently-card rounded-2xl p-5">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-[#f1f1f1]">Events</h1>
      <p class="mt-1 text-sm text-[#7ec0ce]">
        Browse events. Admins and staff can also see drafts they are allowed to manage.
      </p>
    </div>

    <% if (session.authenticatedUser && (session.authenticatedUser.role === "admin" || session.authenticatedUser.role === "staff")) { %>
      <a
        href="/new"
        class="evently-outline rounded-lg px-5 py-2 text-lg font-bold no-underline"
      >
        NEW EVENT
      </a>
    <% } %>
  </div>

  <form method="GET" action="/events/search" class="mb-4">
    <input
      type="text"
      name="query"
      value="<%= query ?? '' %>"
      placeholder="Search published events..."
      hx-get="/events/search"
      hx-target="#event-list"
      hx-swap="innerHTML"
      hx-push-url="true"
      hx-trigger="keyup changed delay:300ms"
      class="evently-input w-full rounded-xl px-4 py-3"
    />
  </form>

  <form
    method="GET"
    action="/events"
    hx-get="/events"
    hx-target="#event-list"
    hx-swap="innerHTML"
    hx-push-url="true"
    class="mb-6 grid gap-4 md:grid-cols-[1fr_1fr_auto]"
  >
    <select name="category" class="evently-input rounded-xl px-4 py-3">
      <option value="">All Categories</option>
      <option value="music" <%= category === 'music' ? 'selected' : '' %>>Music</option>
      <option value="sports" <%= category === 'sports' ? 'selected' : '' %>>Sports</option>
      <option value="academic" <%= category === 'academic' ? 'selected' : '' %>>Academic</option>
      <option value="social" <%= category === 'social' ? 'selected' : '' %>>Social</option>
      <option value="food" <%= category === 'food' ? 'selected' : '' %>>Food</option>
      <option value="arts" <%= category === 'arts' ? 'selected' : '' %>>Arts</option>
      <option value="networking" <%= category === 'networking' ? 'selected' : '' %>>Networking</option>
      <option value="other" <%= category === 'other' ? 'selected' : '' %>>Other</option>
    </select>

    <select name="timeframe" class="evently-input rounded-xl px-4 py-3">
      <option value="">All Time</option>
      <option value="all_upcoming" <%= timeframe === 'all_upcoming' ? 'selected' : '' %>>All Upcoming</option>
      <option value="this_week" <%= timeframe === 'this_week' ? 'selected' : '' %>>This Week</option>
      <option value="this_weekend" <%= timeframe === 'this_weekend' ? 'selected' : '' %>>This Weekend</option>
    </select>

    <button
      type="submit"
      class="evently-primary rounded-lg px-6 py-2 font-bold"
    >
      Filter
    </button>
  </form>

  <div id="event-list">
    <%- include("../partials/event-list", { events, draftEvents: draftEvents ?? [], session }) %>
  </div>
</section>