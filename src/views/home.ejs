<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<% const currentUser = session.authenticatedUser; %>

<section class="mb-5 p-6 border-2 border-[#7ec0ce] rounded-2xl bg-[#16213e] shadow-[0_0_2px_#7ec0ce,inset_0_0_2px_#7ec0ce,0_0_5px_#7ec0ce,0_0_15px_#7ec0ce,0_0_30px_#7ec0ce]">
  <div class="grid gap-6 md:grid-cols-2">
    <% if (currentUser && currentUser.role === "user") { %>
      <section class="rounded-xl border-2 border-[#7ec0ce] bg-[#0d1525] p-5">
        <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl font-bold text-[#f1f1f1]">
          My Upcoming RSVPs
        </h2>

        <div class="rounded-lg bg-[#16213e] p-4">
          <p class="text-sm text-[#7ec0ce]">
            View the events you have RSVP’d to and manage upcoming attendance.
          </p>

          <div class="mt-4 flex justify-center">
            <a
              href="/my-rsvps"
              class="font-bold text-[#df3a9e] no-underline hover:text-[#f1f1f1]"
            >
              VIEW ALL RSVPS
            </a>
          </div>
        </div>
      </section>
    <% } else { %>
      <section class="rounded-xl border-2 border-[#7ec0ce] bg-[#0d1525] p-5">
        <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl font-bold text-[#f1f1f1]">
          My Upcoming Events
        </h2>

        <div class="rounded-lg bg-[#16213e] p-4">
          <p class="text-sm text-[#7ec0ce]">
            View and manage events that you created, including drafts and upcoming published events.
          </p>

          <div class="mt-4 flex justify-center">
            <a
              href="/events"
              class="font-bold text-[#df3a9e] no-underline hover:text-[#f1f1f1]"
            >
              VIEW ALL MY EVENTS
            </a>
          </div>
        </div>
      </section>
    <% } %>

    <section class="rounded-xl border-2 border-[#7ec0ce] bg-[#0d1525] p-5">
      <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl font-bold text-[#f1f1f1]">
        All Upcoming Events
      </h2>

      <div class="rounded-lg bg-[#16213e] p-4">
        <p class="text-sm text-[#7ec0ce]">
          Browse all published upcoming events and open event detail pages.
        </p>

        <div class="mt-4 flex justify-center">
          <a
            href="/events"
            class="font-bold text-[#df3a9e] no-underline hover:text-[#f1f1f1]"
          >
            VIEW ALL EVENTS
          </a>
        </div>
      </div>
    </section>
  </div>

  <div class="mt-8 flex flex-wrap justify-center gap-4">
    <% if (currentUser && (currentUser.role === "admin" || currentUser.role === "staff")) { %>
      <a
        href="/new"
        class="rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#7ec0ce] px-6 py-2 text-lg font-bold no-underline hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
      >
        NEW EVENT
      </a>
    <% } %>

    <% if (currentUser && currentUser.role === "admin") { %>
      <a
        href="/admin/users"
        class="rounded-lg bg-[#16213e] text-[#7ec0ce] border-2 border-[#7ec0ce] px-6 py-2 text-lg font-bold no-underline hover:bg-[#214F82] shadow-[0_0_2px_#7ec0ce,0_0_5px_#7ec0ce]"
      >
        MANAGE USERS
      </a>
    <% } %>

  </div>
</section>