<section class="mb-6 text-center">
  <h1 class="evently-logo text-6xl text-white">EVENTLY</h1>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<% const currentUser = session.authenticatedUser; %>

<section class="grid gap-8 md:grid-cols-2">
  <% if (currentUser && currentUser.role === "user") { %>
    <div class="evently-card rounded-2xl p-5">
      <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl text-[#f1f1f1]">
        My Upcoming RSVPs
      </h2>

      <div class="rounded-lg bg-[#0d1525] p-4 text-[#7ec0ce]">
        <p class="mb-3 text-sm">
          See the events you RSVP’d to, cancel RSVPs, and review your upcoming plans.
        </p>

        <a
          href="/my-rsvps"
          class="text-[#df3a9e] font-bold no-underline hover:text-[#f1f1f1]"
        >
          VIEW ALL RSVPS
        </a>
      </div>
    </div>
  <% } else { %>
    <div class="evently-card rounded-2xl p-5">
      <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl text-[#f1f1f1]">
        My Upcoming Events
      </h2>

      <div class="rounded-lg bg-[#0d1525] p-4 text-[#7ec0ce]">
        <p class="mb-3 text-sm">
          View the events you manage, including drafts that are not visible to members yet.
        </p>

        <a
          href="/events"
          class="text-[#df3a9e] font-bold no-underline hover:text-[#f1f1f1]"
        >
          VIEW ALL MY EVENTS
        </a>
      </div>
    </div>
  <% } %>

  <div class="evently-card rounded-2xl p-5">
    <h2 class="mb-4 border-2 border-[#7ec0ce] px-4 py-2 text-2xl text-[#f1f1f1]">
      All Upcoming Events
    </h2>

    <div class="rounded-lg bg-[#0d1525] p-4 text-[#7ec0ce]">
      <p class="mb-3 text-sm">
        Browse all published upcoming events and open event detail pages.
      </p>

      <a
        href="/events"
        class="text-[#df3a9e] font-bold no-underline hover:text-[#f1f1f1]"
      >
        VIEW ALL EVENTS
      </a>
    </div>
  </div>
</section>

<section class="mt-8 flex flex-wrap justify-center gap-6">
  <% if (currentUser && (currentUser.role === "admin" || currentUser.role === "staff")) { %>
    <a
      href="/new"
      class="evently-outline rounded-lg px-6 py-2 text-xl font-bold no-underline"
    >
      NEW EVENT
    </a>
  <% } %>

  <% if (currentUser && currentUser.role === "admin") { %>
    <a
      href="/admin/users"
      class="evently-outline rounded-lg px-6 py-2 text-xl font-bold no-underline"
    >
      MANAGE USERS
    </a>
  <% } %>
</section>